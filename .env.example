# OpenAI API 키 (https://platform.openai.com/api-keys 에서 발급)
# 이 파일을 복사해 `.env` 로 저장한 뒤 실제 키를 넣으세요.
OPENAI_API_KEY=sk-여기에_본인_키_입력

# Notion 저장용
# GitHub Actions에서는 Settings > Secrets and variables > Actions에 같은 이름으로 등록하세요.
NOTION_TOKEN=ntn_또는_secret_여기에_본인_노션_통합_토큰_입력
NOTION_DATABASE_ID=여기에_노션_데이터베이스_ID_입력

# Obsidian 저장용
# 기본적으로 obsidian/AI News/ 폴더에 Markdown 파일이 저장됩니다.
# Obsidian Local REST API를 사용할 때만 아래 두 값을 설정하세요.
OBSIDIAN_API_KEY=여기에_옵시디언_API_KEY_입력
OBSIDIAN_API_URL=https://127.0.0.1:27124
